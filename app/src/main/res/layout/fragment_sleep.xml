<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tv_sleep_score"
        android:layout_width="55dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="30dp"
        android:text="--"
        android:textColor="#3F51B5"
        android:textSize="60sp" />

    <TextView
        android:id="@+id/tv_sleep_advice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="分析结果"
        android:layout_gravity="center"
        android:layout_marginBottom="30dp" />

    <EditText
        android:id="@+id/et_total_hours"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="总时长 (小时)"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/et_deep_sleep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="深睡时长 (小时)"
        android:inputType="numberDecimal"
        android:layout_marginTop="10dp" />

    <EditText
        android:id="@+id/et_wake_up"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="醒来次数"
        android:inputType="number"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btn_save_sleep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="计算评分并分析"
        android:backgroundTint="#3F51B5"
        android:textColor="#FFFFFF" />
</LinearLayout>